{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": [
    "electron.vite.config.*",
    "src/main/**/*",
    "src/preload/**/*",
    "src/shared/**/*",
    "../../packages/shared/src/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "types": ["electron-vite/node"],
    "baseUrl": ".",
    "paths": {
      "@main/*": ["src/main/*"],
      "@desktop/shared/*": ["src/shared/*"],
      "@peel/shared": ["../../packages/shared/src/index.ts"],
      "@peel/shared/*": ["../../packages/shared/src/*"]
    }
  }
}
