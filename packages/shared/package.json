{
  "name": "@peel/shared",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "description": "Platform-neutral Peel JSON helpers and shared types.",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./json": {
      "types": "./dist/json.d.ts",
      "require": "./dist/json.js",
      "default": "./dist/json.js"
    },
    "./history": {
      "types": "./dist/history.d.ts",
      "require": "./dist/history.js",
      "default": "./dist/history.js"
    },
    "./extraction": {
      "types": "./dist/extraction.d.ts",
      "require": "./dist/extraction.js",
      "default": "./dist/extraction.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "require": "./dist/types.js",
      "default": "./dist/types.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "jsonc-parser": "^3.3.1",
    "jsonpath-plus": "^10.3.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
