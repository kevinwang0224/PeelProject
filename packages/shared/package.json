{
  "name": "@peel/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Platform-neutral Peel JSON helpers and shared types.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./json": {
      "types": "./src/json.ts",
      "default": "./src/json.ts"
    },
    "./history": {
      "types": "./src/history.ts",
      "default": "./src/history.ts"
    },
    "./extraction": {
      "types": "./src/extraction.ts",
      "default": "./src/extraction.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "jsonc-parser": "^3.3.1",
    "jsonpath-plus": "^10.3.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
